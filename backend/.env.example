# ─────────────────────────────────────────────────────────────────────────────
# Solar AI Platform – Environment Variables Example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit your actual .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Solar AI Optimization Platform"
APP_VERSION="1.0.0"
ENVIRONMENT="development"          # development | staging | production
DEBUG=true

# ── API Security ──────────────────────────────────────────────────────────────
# Generate a strong key:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_A_STRONG_RANDOM_SECRET_KEY_HERE

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://127.0.0.1:5500

# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+asyncpg://solar_user:solar_pass@localhost:5432/solar_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# ── File Uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# ── ML Model Paths ────────────────────────────────────────────────────────────
# Paths relative to the directory where uvicorn is launched
SOLAR_FORECAST_MODEL_PATH=../trained-models/solar_forecast_model.pkl
SAVINGS_MODEL_PATH=../trained-models/savings_prediction_model.pkl
YOLO_MODEL_PATH=../trained-models/prediction_yolo.pt

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text                    # text (dev) | json (production)
LOG_FILE=logs/solar_api.log

# ── External Services ─────────────────────────────────────────────────────────
WEATHER_API_KEY=YOUR_OPENWEATHERMAP_API_KEY_HERE
WEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5
